# =============================================================================
# API Keys — copy this file to .env and fill in your values
# =============================================================================

# OpenAI (via GitHub)
OPENAI_API_KEY=<your-new-github-pat>
OPENAI_BASE_URL=https://models.github.ai/inference/v1

# Anthropic (https://console.anthropic.com/settings/keys) — optional
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Google AI / Vertex (https://aistudio.google.com/apikey) — optional
# GOOGLE_API_KEY=your-google-api-key-here

